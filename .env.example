# 本番公開URL(OGP・sitemap・robots.txtの絶対URL生成に使用。未設定時はhttp://localhost:3000)
NEXT_PUBLIC_SITE_URL=https://example.com

# 専門家紹介フォームの問い合わせ先メールアドレス(未設定時はプレースホルダーが使われる)
NEXT_PUBLIC_CONTACT_EMAIL=info@example.com

# 設定するとお問い合わせ内容をこのWebhook URLに転送する(Slack Incoming Webhook等を想定)
# 未設定の場合、フォームは送信後にメールソフトへのフォールバック(mailto)を表示する
CONTACT_NOTIFY_WEBHOOK_URL=
